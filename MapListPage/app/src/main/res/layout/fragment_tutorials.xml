<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/heatmap_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Barra de búsqueda -->
    <LinearLayout
        android:id="@+id/search_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical"
        android:elevation="4dp"
        android:background="#F5F5F5">

        <EditText
            android:id="@+id/search_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Search dances..."
            android:padding="12dp"
            android:background="@drawable/rounded_light_grey_bg"
            android:textColor="#555555"
            android:textColorHint="#888888"
            android:inputType="text" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_search"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Search"
            android:textColor="#4B0082"
            android:backgroundTint="#D8BFF9"
            app:cornerRadius="50dp"
            android:paddingHorizontal="20dp"
            android:paddingVertical="10dp"
            style="@style/Widget.MaterialComponents.Button" />
    </LinearLayout>

    <!-- ScrollView principal para todo el contenido -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="12dp">

            <!-- ========== HIGH MOBILITY SECTION ========== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                app:cardElevation="4dp">

                <!-- LinearLayout VERTICAL dentro del CardView -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Título con fondo degradado y botón info -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/gradient_header"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="High mobility"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Standing up"
                                android:textSize="14sp"
                                android:textColor="#FFFFFF"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <!-- Botón info circular blanco -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/info_button_high"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:text="i"
                            android:textSize="20sp"
                            android:textStyle="italic"
                            android:textColor="#667eea"
                            android:backgroundTint="#FFFFFF"
                            android:textAllCaps="false"
                            app:cornerRadius="20dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:padding="0dp"
                            style="@style/Widget.MaterialComponents.Button" />
                    </LinearLayout>

                    <!-- HorizontalScrollView para los botones -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        android:padding="12dp">

                        <LinearLayout
                            android:id="@+id/high_mobility_buttons"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <!-- Los botones se añadirán dinámicamente desde Java -->
                        </LinearLayout>
                    </HorizontalScrollView>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DDDDDD"
                android:layout_marginVertical="8dp" />

            <!-- ========== MEDIUM MOBILITY SECTION ========== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="16dp"
                app:cardElevation="4dp">

                <!-- LinearLayout VERTICAL dentro del CardView -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Título con fondo degradado y botón info -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/gradient_header"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Medium mobility"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Walker/Cane users"
                                android:textSize="14sp"
                                android:textColor="#FFFFFF"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <!-- Botón info circular blanco -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/info_button_medium"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:text="i"
                            android:textSize="20sp"
                            android:textStyle="italic"
                            android:textColor="#667eea"
                            android:backgroundTint="#FFFFFF"
                            android:textAllCaps="false"
                            app:cornerRadius="20dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:padding="0dp"
                            style="@style/Widget.MaterialComponents.Button" />
                    </LinearLayout>

                    <!-- HorizontalScrollView para los botones -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        android:padding="12dp">

                        <LinearLayout
                            android:id="@+id/medium_mobility_buttons"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <!-- Los botones se añadirán dinámicamente desde Java -->
                        </LinearLayout>
                    </HorizontalScrollView>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DDDDDD"
                android:layout_marginVertical="8dp" />

            <!-- ========== LOW MOBILITY SECTION ========== -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                android:layout_marginBottom="16dp"
                app:cardElevation="4dp">

                <!-- LinearLayout VERTICAL dentro del CardView -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Título con fondo degradado y botón info -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:background="@drawable/gradient_header"
                        android:padding="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Low mobility"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Wheelchair users"
                                android:textSize="14sp"
                                android:textColor="#FFFFFF"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>

                        <!-- Botón info circular blanco -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/info_button_low"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:text="i"
                            android:textSize="20sp"
                            android:textStyle="italic"
                            android:textColor="#667eea"
                            android:backgroundTint="#FFFFFF"
                            android:textAllCaps="false"
                            app:cornerRadius="20dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp"
                            android:padding="0dp"
                            style="@style/Widget.MaterialComponents.Button" />
                    </LinearLayout>

                    <!-- HorizontalScrollView para los botones -->
                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none"
                        android:padding="12dp">

                        <LinearLayout
                            android:id="@+id/low_mobility_buttons"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <!-- Los botones se añadirán dinámicamente desde Java -->
                        </LinearLayout>
                    </HorizontalScrollView>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ========== ESPACIO PARA DORITO (MASCOTA) ========== -->
            <LinearLayout
                android:id="@+id/dorito_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="end"
                android:padding="24dp"
                android:layout_marginTop="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:layout_marginEnd="40dp">

                    <!-- Help label encima de Dorito -->
                    <TextView
                        android:id="@+id/help_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Help?"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/white"
                        android:background="@drawable/warning_badge"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="6dp"
                        android:layout_marginBottom="8dp" />

                    <!-- Animación Lottie de Dorito más pequeña -->
                    <com.airbnb.lottie.LottieAnimationView
                        android:id="@+id/dorito_button"
                        android:layout_width="80dp"
                        android:layout_height="80dp"
                        android:background="@android:color/transparent"
                        app:lottie_fileName="help_animation.json"
                        app:lottie_autoPlay="true"
                        app:lottie_loop="true" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>